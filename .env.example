# Ejemplo de variables de entorno para el proyecto
# Copia este archivo como .env y ajusta los valores según tu entorno

# Puerto del servidor
PORT=8080

# Ruta de la base de datos SQLite
DB_PATH=./db/app.db

# Secreto para JWT o autenticación
JWT_SECRET=change-me-in-production

# Modo de ejecución
GIN_MODE=debug

# Configuración de Docker Compose (opcional)
POSTGRES_DB=carritosdb
POSTGRES_USER=carritos
POSTGRES_PASSWORD=carritos123
